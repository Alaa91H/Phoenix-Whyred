# Hybrid 6.18 LTS product fragment (on top of gki_defconfig)
# NOTE: Only add options unique to this fragment.
# Duplicates with other fragments (MODULES, ZRAM, CMA, ANDROID, PSTORE, etc.)
# are intentionally NOT here — they live in android-gki/hybrid/whyred.config.

CONFIG_LOCALVERSION_AUTO=y

# LTS-specific
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
CONFIG_MAGIC_SYSRQ=y

# Dev flexibility (disable MODULE_SIG_FORCE for bring-up)
# CONFIG_MODULE_SIG_FORCE is not set
