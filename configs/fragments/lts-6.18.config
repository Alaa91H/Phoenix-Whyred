# Hybrid 6.18 LTS product fragment (on top of gki_defconfig)

CONFIG_LOCALVERSION_AUTO=y

# Stable / LTS-friendly
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# Android userspace
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"

# Memory pressure on 4/6GB whyred
CONFIG_ZRAM=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_PSI=y
CONFIG_CMA=y
CONFIG_DMA_CMA=y

# QCOM / SDM660 family
CONFIG_ARCH_QCOM=y
CONFIG_OF=y
CONFIG_OF_OVERLAY=y

# Crash diagnostics
CONFIG_PSTORE=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_RAM=y
CONFIG_MAGIC_SYSRQ=y

# Dev flexibility (disable MODULE_SIG_FORCE for bring-up)
# CONFIG_MODULE_SIG_FORCE is not set
