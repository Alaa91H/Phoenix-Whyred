# Hybrid glue: GKI + mainline-ish SDM660 + Android product needs

# Keep modules loadable for vendor bits
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=n

# Device tree
CONFIG_OF=y
CONFIG_OF_OVERLAY=y
CONFIG_BUILD_ARM64_DT_OVERLAY=y

# CMA / ION replacement
CONFIG_CMA=y
CONFIG_DMA_CMA=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_CMA=y
CONFIG_DMABUF_HEAPS_SYSTEM=y

# ZRAM / memory pressure (useful on 4/6 GB whyred)
CONFIG_ZRAM=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZSWAP=y

# Scheduler / power
CONFIG_SCHED_MC=y
CONFIG_ENERGY_MODEL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# Android binder
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"

# Disable BTF (resolve_btfids Invalid argument with clang on CI)
# CONFIG_DEBUG_INFO_BTF is not set
# CONFIG_DEBUG_INFO_BTF_MODULES is not set

# pstore / ramoops for crash debugging
CONFIG_PSTORE=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y
CONFIG_PSTORE_RAM=y
