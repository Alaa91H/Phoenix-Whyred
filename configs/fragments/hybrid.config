# Mainline glue: minimal first-boot essentials

# Modules (keep loadable for flexibility)
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODVERSIONS=y
CONFIG_MODULE_SIG=y
# CONFIG_MODULE_SIG_FORCE is not set

# Device tree
CONFIG_OF=y
CONFIG_OF_OVERLAY=y
CONFIG_BUILD_ARM64_DT_OVERLAY=y

# CMA / DMA (required for USB, MMC, display)
CONFIG_CMA=y
CONFIG_DMA_CMA=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_CMA=y
CONFIG_DMABUF_HEAPS_SYSTEM=y

# Scheduler (minimal)
CONFIG_SCHED_MC=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# Disable BTF (resolve_btfids Invalid argument with clang on CI)
# CONFIG_DEBUG_INFO_BTF is not set
# CONFIG_DEBUG_INFO_BTF_MODULES is not set

# NOT enabled for first boot (add in later stages):
# CONFIG_ZRAM is not set
# CONFIG_ZSWAP is not set
# CONFIG_ENERGY_MODEL is not set
# CONFIG_PSTORE is not set
