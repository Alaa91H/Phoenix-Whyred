# Device-specific fragment: Xiaomi whyred (SDM636)
# Minimal first-boot configuration — P0 items only
# Linux Mainline 6.18 LTS
#
# This fragment enables ONLY what is required for:
#   kernel build → DTB → UART console → eMMC → USB
# Everything else (display, touch, GPU, audio, camera, Wi-Fi, etc.)
# is added in later stages.

# ── Platform ──────────────────────────────────────────────
CONFIG_ARCH_QCOM=y
CONFIG_PINCTRL_SDM660=y
CONFIG_SDM_GCC_660=y
CONFIG_COMMON_CLK_QCOM=y
CONFIG_QCOM_GDSC=y
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SMSM=y
CONFIG_QCOM_SMP2P=y
CONFIG_QCOM_SOCINFO=y
CONFIG_QCOM_PDC=y
CONFIG_QCOM_AOSS_QMP=y
CONFIG_QCOM_GENI_SE=y
CONFIG_QCOM_TSENS=y
CONFIG_QCOM_SPMI_TEMP_ALARM=y

# ── Serial (UART console) ────────────────────────────────
CONFIG_SERIAL_QCOM_GENI=y
CONFIG_SERIAL_QCOM_GENI_CONSOLE=y
CONFIG_SERIAL_EARLYCON=y

# ── PMIC ──────────────────────────────────────────────────
CONFIG_SPMI_MSM_PMIC_ARB=y
CONFIG_MFD_SPMI_PMIC=y
CONFIG_REGULATOR_QCOM_SPMI=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_INPUT_PM8941_PWRKEY=y

# ── Storage (eMMC) ────────────────────────────────────────
CONFIG_MMC=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_MSM=y
CONFIG_MMC_BLOCK=y
CONFIG_EXT4_FS=y

# ── USB (debugging) ──────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_USB_PHY=y
CONFIG_PHY_QCOM_QUSB2=y
CONFIG_PHY_QCOM_USB_HS=y
CONFIG_EXTCON_USB_GPIO=y
CONFIG_TYPEC=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_RNDIS=y

# ── I2C (needed for touch in later stages) ────────────────
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_QCOM_GENI=y

# ── SPI (general bus support) ─────────────────────────────
CONFIG_SPI_GENI_QCOM=y

# ── Crypto / Security ─────────────────────────────────────
CONFIG_CRYPTO_DEV_QCE=y

# ── Hardware spinlock ─────────────────────────────────────
CONFIG_HWSPINLOCK_QCOM=y

# ── Remote processor (modem — may fail without firmware, non-blocking) ──
CONFIG_REMOTEPROC=y
CONFIG_QCOM_Q6V5_MSS=y
CONFIG_QCOM_SYSMON=y
CONFIG_QCOM_PIL_INFO=y
CONFIG_QCOM_RPROC_COMMON=y

# ── QRTR (modem IPC — may fail without firmware, non-blocking) ──
CONFIG_QRTR=y
CONFIG_QRTR_SMD=y
CONFIG_RPMSG_QCOM_GLINK_RPM=y

# ── Keyboard ──────────────────────────────────────────────
CONFIG_KEYBOARD_GPIO=y

# ── NOT enabled for first boot (added in later stages) ────
# CONFIG_DRM_MSM is not set
# CONFIG_DRM_MSM_DSI is not set
# CONFIG_FB_SIMPLE is not set
# CONFIG_BACKLIGHT_CLASS_DEVICE is not set
# CONFIG_TOUCHSCREEN_NT36XXX is not set
# CONFIG_ATH10K is not set
# CONFIG_SND_SOC_WCD9335 is not set
# CONFIG_BATTERY_QCOM_BATTMGR is not set
# CONFIG_CHARGER_QCOM_SMB2 is not set
# CONFIG_WHYRED_DRIVERS is not set
# CONFIG_WHYRED_BOARD is not set

# ── Board glue (disabled for minimal first boot) ──────────
# CONFIG_WHYRED_DRIVERS is not set
