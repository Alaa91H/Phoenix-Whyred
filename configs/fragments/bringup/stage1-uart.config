# Bring-up stage 1: UART console + earlycon only
# BRINGUP_STAGE=1

CONFIG_SERIAL_MSM=y
CONFIG_SERIAL_MSM_CONSOLE=y
CONFIG_SERIAL_EARLYCON=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PRINTK=y
CONFIG_BLK_DEV_INITRD=y

# Keep storage/USB/display/touch soft until later stages (may still be =y from base)
# Prefer not disabling core bus; stage gating is primarily via DT.

CONFIG_WHYRED_BOARD=y
# CONFIG_WHYRED_DISPLAY is not set
# CONFIG_WHYRED_TOUCH is not set
