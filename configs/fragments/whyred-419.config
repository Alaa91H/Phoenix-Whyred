# Optional extras on top of vendor/whyred-perf_defconfig (4.19 track)
# Keep minimal — the vendor defconfig already enables device drivers.

# Local branding
CONFIG_LOCALVERSION="-whyred-419"

# Useful for custom ROMs / recovery debugging
CONFIG_KPROBES=y
CONFIG_HAVE_KPROBES=y
# CONFIG_MODULE_SIG_FORCE is not set

# ZRAM (if not already on)
CONFIG_ZRAM=y
