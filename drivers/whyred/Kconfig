menuconfig WHYRED_DRIVERS
	bool "Xiaomi whyred (Redmi Note 5 Pro) device drivers"
	depends on ARCH_QCOM || COMPILE_TEST
	default y if ARCH_QCOM
	help
	  Board glue and helpers for Xiaomi whyred mainline kernel.
	  Most hardware is handled by upstream drivers via DT.

if WHYRED_DRIVERS

config WHYRED_BOARD
	tristate "Whyred board platform driver"
	default y
	help
	  Sysfs identity and panel geometry from DT (xiaomi,whyred-board).
	  Optional — provides board identification via sysfs.

endif # WHYRED_DRIVERS
